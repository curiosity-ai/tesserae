{
  "output": "$(OutDir)/h5/",
  "fileName": "app.js",
  "html": {
    "disabled": false,
    "title": "Tesserae Benchmark Harness"
  },
  "resources": [],
  "cleanOutputFolderBeforeBuildPattern": "*.js|*.css|*.dontload",
  "console": { "enabled": false },
  "loader": { "type": "Global" },
  "sourceMap": { "enabled": true },
  "reflection": {
    "disabled": false,
    "target": "inline"
  },
  "generateTypeScript": false,
  "report": { "enabled": false },
  "rules": {
    "anonymousType": "Plain",
    "arrayIndex": "Managed",
    "autoProperty": "Plain",
    "boxing": "Managed",
    "externalCast": "Plain",
    "inlineComment": "Plain",
    "integer": "Managed",
    "lambda": "Plain",
    "useShortForms": true
  }
}
